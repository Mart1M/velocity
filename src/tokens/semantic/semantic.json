{
  "velocity": {
    "background": {
      "primary": {
        "$value": "{color.gray.950}",
        "$type": "color"
      },
      "secondary": {
        "$value": "{color.gray.900}",
        "$type": "color"
      },
      "tertiary": {
        "$value": "{color.gray.800}",
        "$type": "color"
      },
      "brand": {
        "$value": "{color.primary.500}",
        "$type": "color"
      },
      "inverse": {
        "$value": "{color.white}",
        "$type": "color"
      }
    },
    "surface": {
      "primary": {
        "$value": "{color.gray.900}",
        "$type": "color"
      },
      "secondary": {
        "$value": "{color.gray.850}",
        "$type": "color"
      },
      "tertiary": {
        "$value": "{color.gray.800}",
        "$type": "color"
      },
      "hover": {
        "$value": "{color.gray.800}",
        "$type": "color"
      },
      "active": {
        "$value": "{color.gray.750}",
        "$type": "color"
      },
      "elevated": {
        "$value": "{color.gray.900}",
        "$type": "color"
      },
      "overlay": {
        "$value": "rgb(0 0 0 / 0.6)",
        "$type": "color"
      }
    },
    "content": {
      "primary": {
        "$value": "{color.white}",
        "$type": "color"
      },
      "secondary": {
        "$value": "{color.gray.300}",
        "$type": "color"
      },
      "tertiary": {
        "$value": "{color.gray.500}",
        "$type": "color"
      },
      "brand": {
        "$value": "{color.primary.400}",
        "$type": "color"
      },
      "inverse": {
        "$value": "{color.gray.900}",
        "$type": "color"
      },
      "disabled": {
        "$value": "{color.gray.600}",
        "$type": "color"
      }
    },
    "border": {
      "default": {
        "$value": "{color.gray.800}",
        "$type": "color"
      },
      "subtle": {
        "$value": "{color.gray.850}",
        "$type": "color"
      },
      "strong": {
        "$value": "{color.gray.700}",
        "$type": "color"
      },
      "brand": {
        "$value": "{color.primary.500}",
        "$type": "color"
      },
      "focus": {
        "$value": "{color.primary.400}",
        "$type": "color"
      }
    },
    "accent": {
      "primary": {
        "$value": "{color.primary.500}",
        "$type": "color"
      },
      "secondary": {
        "$value": "{color.primary.300}",
        "$type": "color"
      },
      "tertiary": {
        "$value": "{color.primary.200}",
        "$type": "color"
      }
    },

    "brand": {
      "primary":   { "$value": "{color.primary.500}",   "$type": "color" },
      "secondary": { "$value": "{color.secondary.300}", "$type": "color" }
    },
    "state": {
      "success": {
        "$value": "{color.green.500}",
        "$type": "color"
      },
      "warning": {
        "$value": "{color.orange.500}",
        "$type": "color"
      },
      "error": {
        "$value": "{color.red.500}",
        "$type": "color"
      },
      "info": {
        "$value": "{color.blue.500}",
        "$type": "color"
      }
    },
    "feedback": {
      "positive": {
        "$value": "{color.green.400}",
        "$type": "color"
      },
      "neutral": {
        "$value": "{color.blue.400}",
        "$type": "color"
      },
      "caution": {
        "$value": "{color.orange.400}",
        "$type": "color"
      },
      "negative": {
        "$value": "{color.red.400}",
        "$type": "color"
      }
    },
    "elevation": {
      "sm": {
        "$value": "0 1px 2px rgba(0,0,0,0.4)",
        "$type": "shadow"
      },
      "md": {
        "$value": "0 4px 12px rgba(0,0,0,0.5)",
        "$type": "shadow"
      },
      "lg": {
        "$value": "0 8px 24px rgba(0,0,0,0.6)",
        "$type": "shadow"
      }
    },
    "motion": {
      "duration": {
        "fast": {
          "$value": "100ms",
          "$type": "duration"
        },
        "normal": {
          "$value": "200ms",
          "$type": "duration"
        },
        "slow": {
          "$value": "300ms",
          "$type": "duration"
        }
      },
      "easing": {
        "standard": {
          "$value": "cubic-bezier(0.4, 0, 0.2, 1)",
          "$type": "cubicBezier"
        }
      }
    }
  }
}