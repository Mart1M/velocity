      "brand-emphasis":   { "$value": "rgb(208 244 0 / 0.20)",  "$type": "color" }
    },
    "brand": {
      "secondary": { "$value": "{color.yellow.300}", "$type": "color" }
    },
    "state": {
      "success": { "$value": "{color.green.500}", "$type": "color" },
