{
  "velocity": {
    "accent": {
      "primary": { "$value": "{color.primary.500}", "$type": "color" },
      "secondary": { "$value": "{color.primary.300}", "$type": "color" },
      "tertiary": { "$value": "{color.primary.200}", "$type": "color" }
    },
    "brand": {
      "primary": { "$value": "{color.primary.500}", "$type": "color" },
      "secondary": { "$value": "{color.secondary.300}", "$type": "color" }
    },
    "state": {
      "success": { "$value": "{color.green.500}", "$type": "color" },
      "warning": { "$value": "{color.orange.500}", "$type": "color" },
      "error": { "$value": "{color.red.500}", "$type": "color" },
      "info": { "$value": "{color.blue.500}", "$type": "color" }
    },
    "feedback": {
      "positive": { "$value": "{color.green.400}", "$type": "color" },
      "neutral": { "$value": "{color.blue.400}", "$type": "color" },
      "caution": { "$value": "{color.orange.400}", "$type": "color" },
      "negative": { "$value": "{color.red.400}", "$type": "color" }
    },
    "motion": {
      "duration": {
        "fast": { "$value": "100ms", "$type": "duration" },
        "normal": { "$value": "200ms", "$type": "duration" },
        "slow": { "$value": "300ms", "$type": "duration" }
      },
      "easing": {
        "standard": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" }
      }
    }
  }
}
