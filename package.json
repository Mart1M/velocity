{
  "name": "@runswap/velocity",
  "version": "0.1.0",
  "description": "Velocity Design System by Runswap",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tokens": {
      "import": "./dist/tokens/index.js",
      "types": "./dist/tokens/index.d.ts"
    },
    "./styles": "./src/styles/tokens.css"
  },
  "files": [
    "dist",
    "src/styles/tokens.css"
  ],
  "scripts": {
    "build:tokens": "tsx scripts/build-tokens.ts",
    "build": "npm run build:tokens && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "peerDependencies": {
    "@base-ui-components/react": "^1.0.0-alpha.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@base-ui-components/react": "^1.0.0-alpha.8",
    "@storybook/addon-a11y": "^8.6.12",
    "@storybook/addon-essentials": "^8.6.12",
    "@storybook/addon-interactions": "^8.6.12",
    "@storybook/addon-themes": "^8.6.18",
    "@storybook/react": "^8.6.12",
    "@storybook/react-vite": "^8.6.12",
    "@storybook/test": "^8.6.12",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.12",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "vite": "^6.2.3"
  }
}
